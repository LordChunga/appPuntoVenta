<Window x:Class="MiniPosWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Despensa Isabel - Punto de Venta"
        Height="820"
        Width="1280"
        MinHeight="720"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        Foreground="White"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="AppBackground" Color="#121212" />
        <SolidColorBrush x:Key="SidebarBackground" Color="#17171C" />
        <SolidColorBrush x:Key="PanelBackground" Color="#1E1E24" />
        <SolidColorBrush x:Key="PanelBackgroundAlt" Color="#24242C" />
        <SolidColorBrush x:Key="InputBackground" Color="#2A2A33" />
        <SolidColorBrush x:Key="AccentBrush" Color="#5E42A6" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#33295A" />
        <SolidColorBrush x:Key="TotalBrush" Color="#00E676" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B6B6C3" />
        <SolidColorBrush x:Key="DimTextBrush" Color="#7E7E8B" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundAlt}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#B3261E" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="SmallIconButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackground}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBackground}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,24,0" />
                                        <TextBlock Text="&#xE70D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{StaticResource InputBackground}"
                                        CornerRadius="8"
                                        BorderBrush="#3A3A44"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="260">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource InputBackground}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#30303A" />
            <Setter Property="RowBackground" Value="{StaticResource PanelBackground}" />
            <Setter Property="AlternatingRowBackground" Value="#202028" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#24242C" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBackground}" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,34">
                    <Border Width="46" Height="46" CornerRadius="23" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="D" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Despensa Isabel" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Propietario" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="OPERACION" Foreground="{StaticResource DimTextBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ListBox SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}">
                        <ListBoxItem Content="Punto de Venta" />
                        <ListBoxItem Content="Productos" />
                        <ListBoxItem Content="Inventario" />
                        <ListBoxItem Content="Compras" />
                        <ListBoxItem Content="Métricas" />
                        <ListBoxItem Content="Clientes" />
                    </ListBox>
                </StackPanel>

                <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="16" Margin="0,22,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" FontSize="18" Margin="0,0,10,0" />
                            <StackPanel>
                                <TextBlock Text="Mi Caja" FontWeight="SemiBold" />
                                <TextBlock Text="Abierta" FontSize="12" Foreground="{StaticResource TotalBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="$1000.00" FontSize="24" FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal">
                    <Border Width="38" Height="38" CornerRadius="19" Background="#2A2A33">
                        <TextBlock Text="I" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Isabel" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Column="1"
                    Margin="28"
                    SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}">
            <TabItem Header="POS">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Punto de Venta" FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="Escanea o ingresa un codigo, revisa el carrito y confirma la venta." Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource PanelBorder}" Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Buscar por id, nombre, codigo interno o codigo de barras" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                                        <TextBox Text="{Binding SaleSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="18">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter" Command="{Binding AddSaleSearchToCartCommand}" />
                                            </TextBox.InputBindings>
                                        </TextBox>
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Content="Agregar"
                                            Style="{StaticResource PrimaryButton}"
                                            VerticalAlignment="Bottom"
                                            Command="{Binding AddSaleSearchToCartCommand}" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <DataGrid ItemsSource="{Binding SaleProductResults}"
                                              IsReadOnly="True"
                                              MaxHeight="170">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70" />
                                            <DataGridTextColumn Header="Producto" Binding="{Binding Name}" Width="*" />
                                            <DataGridTextColumn Header="Codigo" Binding="{Binding InternalCode}" Width="110" />
                                            <DataGridTextColumn Header="Barras" Binding="{Binding Barcode}" Width="130" />
                                            <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="70" />
                                            <DataGridTemplateColumn Header="" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Agregar"
                                                                Style="{StaticResource PrimaryButton}"
                                                                Command="{Binding DataContext.AddProductToCartCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <DataGrid Grid.Row="2" ItemsSource="{Binding Cart}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Codigo" Binding="{Binding Code}" Width="130" IsReadOnly="True" />
                                            <DataGridTextColumn Header="Producto" Binding="{Binding Name}" Width="*" IsReadOnly="True" />
                                            <DataGridTemplateColumn Header="Cant." Width="130">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Button Content="-" Style="{StaticResource SmallIconButton}"
                                                                    Command="{Binding DataContext.DecrementCartItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                    CommandParameter="{Binding}" />
                                                            <TextBlock Text="{Binding Quantity}" Width="34" HorizontalAlignment="Center" TextAlignment="Center" />
                                                            <Button Content="+" Style="{StaticResource SmallIconButton}"
                                                                    Command="{Binding DataContext.IncrementCartItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                    CommandParameter="{Binding}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Unitario" Binding="{Binding UnitPrice, StringFormat=C}" Width="110" IsReadOnly="True" />
                                            <DataGridTextColumn Header="Subtotal" Binding="{Binding LineTotal, StringFormat=C}" Width="120" IsReadOnly="True" />
                                            <DataGridTemplateColumn Header="" Width="58">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource DangerButton}"
                                                                Command="{Binding DataContext.RemoveCartItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="Eliminar">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" />
                                                        </Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Cliente" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                                    <ComboBox ItemsSource="{Binding PosClients}"
                                              SelectedItem="{Binding SelectedPosClient}"
                                              TextSearch.TextPath="Nombre"
                                              IsEditable="False">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Nombre}" Foreground="{StaticResource TextBrush}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Text="Sin cliente = Consumidor Final"
                                               Foreground="{StaticResource DimTextBrush}"
                                               FontSize="11" Margin="0,4,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Row="2">
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="Items" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding ItemsCount}" HorizontalAlignment="Right" />
                                    </Grid>
                                    <Grid Margin="0,0,0,22">
                                        <TextBlock Text="Subtotal" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding Subtotal, StringFormat=C}" HorizontalAlignment="Right" />
                                    </Grid>

                                    <!-- Método de Pago -->
                                    <TextBlock Text="Método de Pago"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,0,0,8" />
                                    <UniformGrid Columns="3" Margin="0,0,0,18">
                                        <UniformGrid.Resources>
                                            <Style x:Key="MetodoPagoBtn" TargetType="Button">
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="BorderBrush" Value="#3A3A44"/>
                                                <Setter Property="Background" Value="#24242C"/>
                                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                                <Setter Property="Padding" Value="4,10"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="8"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </UniformGrid.Resources>

                                        <!-- Efectivo -->
                                        <Button Content="💵 Efectivo"
                                                Margin="0,0,6,6"
                                                Command="{Binding SetMetodoPagoCommand}"
                                                CommandParameter="Efectivo">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MetodoPagoBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MetodoPago}" Value="Efectivo">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Débito -->
                                        <Button Content="💳 Débito"
                                                Margin="0,0,6,6"
                                                Command="{Binding SetMetodoPagoCommand}"
                                                CommandParameter="Débito">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MetodoPagoBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MetodoPago}" Value="Débito">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Crédito -->
                                        <Button Content="💳 Crédito"
                                                Margin="0,0,0,6"
                                                Command="{Binding SetMetodoPagoCommand}"
                                                CommandParameter="Crédito">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MetodoPagoBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MetodoPago}" Value="Crédito">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Transferencia -->
                                        <Button Content="🏦 Transfer."
                                                Margin="0,0,6,0"
                                                Command="{Binding SetMetodoPagoCommand}"
                                                CommandParameter="Transferencia">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MetodoPagoBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MetodoPago}" Value="Transferencia">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- QR -->
                                        <Button Content="📱 QR"
                                                Margin="0,0,6,6"
                                                Command="{Binding SetMetodoPagoCommand}"
                                                CommandParameter="QR / Billetera digital">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MetodoPagoBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MetodoPago}" Value="QR / Billetera digital">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Cuenta Corriente -->
                                        <Button Content="📒 Cta. Cte."
                                                Margin="0,0,6,0"
                                                Command="{Binding SetMetodoPagoCommand}"
                                                CommandParameter="Cuenta Corriente">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MetodoPagoBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MetodoPago}" Value="Cuenta Corriente">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Seleccionado actual (label) -->
                                        <Border CornerRadius="8" Background="#1A1A22" Margin="0">
                                            <TextBlock Text="{Binding MetodoPago}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       Padding="4"/>
                                        </Border>
                                    </UniformGrid>

                                    <!-- Bug 1: Viewbox con ancho completo para escalar el Total sin cortes -->
                                    <Viewbox Height="52" HorizontalAlignment="Stretch" Stretch="Uniform" Margin="0,0,0,18">
                                        <TextBlock Text="{Binding Total, StringFormat=Total {0:C}}"
                                                   Foreground="{StaticResource TotalBrush}"
                                                   FontSize="38"
                                                   FontWeight="Bold" />
                                    </Viewbox>
                                    <!-- Confirmar Venta: habilitado automaticamente por CanConfirmSale() via CanExecuteChanged -->
                                    <Button Content="Confirmar Venta"
                                            Style="{StaticResource PrimaryButton}"
                                            FontSize="16"
                                            MinHeight="64"
                                            Margin="0,0,0,12"
                                            Command="{Binding ConfirmSaleCommand}" />
                                    <Button Content="Vaciar Carrito"
                                            Style="{StaticResource RoundedButton}"
                                            Background="#33333C"
                                            Command="{Binding ClearCartCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Productos">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Productos" FontSize="32" FontWeight="Bold" />
                            <TextBlock Text="Alta, edicion y baja de productos." Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="+ Importar archivo"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Top"
                                Command="{Binding ImportProductsCommand}" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource PanelBorder}" Padding="18">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Carga de producto" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />
                                <TextBlock Grid.Row="1" Text="Codigo de barras" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                <TextBox Grid.Row="2" Margin="0,0,0,10" Text="{Binding ProductBarcode, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="3" Text="Codigo interno" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                <TextBox Grid.Row="4" Margin="0,0,0,10" Text="{Binding ProductInternalCode, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="5" Text="Nombre" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                <TextBox Grid.Row="6" Margin="0,0,0,10" Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="7" Text="Precio de venta" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                <TextBox Grid.Row="8" Margin="0,0,0,10" Text="{Binding ProductSalePrice, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="9" Text="Stock actual" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                <TextBox Grid.Row="10" Margin="0,0,0,10" Text="{Binding ProductStock, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="11" Text="Categoria" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                <ComboBox Grid.Row="12" Margin="0,0,0,10"
                                          ItemsSource="{Binding Categories}"
                                          SelectedItem="{Binding SelectedCategory}"
                                          TextSearch.TextPath="Name">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid Grid.Row="13" VerticalAlignment="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Nueva categoria" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                        <TextBox Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="+ Categoria" Style="{StaticResource RoundedButton}" Command="{Binding CreateCategoryCommand}" />
                                </Grid>

                                <UniformGrid Grid.Row="25" Columns="3" Margin="0,30,0,0">
                                    <Button Content="Nuevo" Margin="0,0,9,0" Style="{StaticResource RoundedButton}" Command="{Binding NewProductCommand}" />
                                    <Button Content="Guardar" Margin="0,0,9,0" Style="{StaticResource PrimaryButton}" Command="{Binding SaveProductCommand}" />
                                    <Button Content="Eliminar" Style="{StaticResource RoundedButton}" Command="{Binding DeleteProductCommand}" />
                                </UniformGrid>
                            </Grid>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="16">
                            <DataGrid ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" IsReadOnly="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.CanContentScroll="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Codigo" Binding="{Binding InternalCode}" Width="130" />
                                    <DataGridTextColumn Header="Barras" Binding="{Binding Barcode}" Width="150" />
                                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Categoria" Binding="{Binding CategoryName}" Width="150" />
                                    <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="90" />
                                    <DataGridTextColumn Header="Precio" Binding="{Binding SalePrice, StringFormat=C}" Width="110" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Inventario">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Inventario" FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="Consulta de stock y precios." Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                    </StackPanel>

                    <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Buscar por id, nombre o codigo" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                                    <TextBox Text="{Binding InventorySearchText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Content="Buscar"
                                        Style="{StaticResource PrimaryButton}"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding SearchProductsCommand}" />
                            </Grid>
                            <!-- Bug 4: ScrollViewer.VerticalScrollBarVisibility=Auto en Inventario -->
                            <DataGrid Grid.Row="2" ItemsSource="{Binding Products}" IsReadOnly="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.CanContentScroll="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Codigo" Binding="{Binding InternalCode}" Width="160" />
                                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Categoria" Binding="{Binding CategoryName}" Width="180" />
                                    <DataGridTextColumn Header="Stock actual" Binding="{Binding Stock}" Width="130" />
                                    <DataGridTextColumn Header="Precio" Binding="{Binding SalePrice, StringFormat=C}" Width="130" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Compras">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Compras" FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="Ingreso de mercaderia y actualizacion inmediata de stock." Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="430" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource PanelBorder}" Padding="18" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Ingreso de stock" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />
                                <TextBlock Text="Buscar producto" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                                <TextBox Margin="0,0,0,12" Text="{Binding PurchaseProductSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Producto" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                                <ComboBox Margin="0,0,0,12"
                                          ItemsSource="{Binding PurchaseProducts}"
                                          SelectedItem="{Binding PurchaseProduct}"
                                          TextSearch.TextPath="Name">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="Cantidad comprada" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                                <TextBox Margin="0,0,0,16" Text="{Binding PurchaseQuantity, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="Confirmar ingreso" Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmPurchaseCommand}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="16">
                            <!-- Bug 4: ScrollViewer.VerticalScrollBarVisibility=Auto en Compras -->
                            <DataGrid ItemsSource="{Binding Products}" IsReadOnly="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.CanContentScroll="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Codigo" Binding="{Binding InternalCode}" Width="150" />
                                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Categoria" Binding="{Binding CategoryName}" Width="160" />
                                    <DataGridTextColumn Header="Stock actual" Binding="{Binding Stock}" Width="130" />
                                    <DataGridTextColumn Header="Precio" Binding="{Binding SalePrice, StringFormat=C}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════ MÉTRICAS ═══════════════════ -->
            <TabItem Header="Métricas">
                <Grid DataContext="{Binding Metricas}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- ── Encabezado ── -->
                    <StackPanel>
                        <TextBlock Text="Métricas" FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="Resumen de ventas, ingresos y tendencias del negocio."
                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                    </StackPanel>

                    <!-- ── KPI Cards ── -->
                    <UniformGrid Grid.Row="2" Columns="4" HorizontalAlignment="Stretch">

                        <!-- KPI 1: Total de Ventas -->
                        <Border Margin="0,0,14,0" CornerRadius="12" Background="#1E1E24" Padding="20,18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="36" Height="36" CornerRadius="8" Background="#2A2A40">
                                        <TextBlock Text="&#xE8C3;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="#818CF8"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Grid.Row="2" Text="{Binding TotalVentas}"
                                           FontSize="36" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Grid.Row="4" Text="Total de Ventas"
                                           FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                            </Grid>
                        </Border>

                        <!-- KPI 2: Ingresos Totales -->
                        <Border Margin="0,0,14,0" CornerRadius="12" Background="#1E1E24" Padding="20,18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8" Background="#1A3020">
                                    <TextBlock Text="&#xE8D1;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#00E676"/>
                                </Border>
                                <Viewbox Grid.Row="2" MaxHeight="46" HorizontalAlignment="Left" Stretch="Uniform">
                                    <TextBlock Text="{Binding IngresosTotales, StringFormat=C}"
                                               FontSize="34" FontWeight="Bold" Foreground="#00E676"/>
                                </Viewbox>
                                <TextBlock Grid.Row="4" Text="Ingresos Totales"
                                           FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                            </Grid>
                        </Border>

                        <!-- KPI 3: Método de Pago Más Usado -->
                        <Border Margin="0,0,14,0" CornerRadius="12" Background="#1E1E24" Padding="20,18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8" Background="#1A2840">
                                    <TextBlock Text="&#xE8C0;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#38BDF8"/>
                                </Border>
                                <TextBlock Grid.Row="2" Text="{Binding MetodoPagoMasUsado}"
                                           FontSize="26" FontWeight="Bold" Foreground="White"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Row="4" Text="Método Más Usado"
                                           FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                            </Grid>
                        </Border>

                        <!-- KPI 4: Producto Más Popular -->
                        <Border CornerRadius="12" Background="#1E1E24" Padding="20,18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8" Background="#2A1A10">
                                    <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#FB923C"/>
                                </Border>
                                <TextBlock Grid.Row="2" Text="{Binding ProductoMasPopular}"
                                           FontSize="22" FontWeight="Bold" Foreground="White"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Row="4" Text="Producto Más Popular"
                                           FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                            </Grid>
                        </Border>
                    </UniformGrid>

                    <!-- ── Ventas Realizadas: búsqueda + DataGrid ── -->
                    <Border Grid.Row="4" Background="#1E1E24" CornerRadius="12" Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Título + Refresh -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Ventas Realizadas" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding StatusMessage}"
                                               Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="↻ Actualizar"
                                        Style="{StaticResource PrimaryButton}"
                                        VerticalAlignment="Top"
                                        Command="{Binding LoadCommand}"/>
                            </Grid>

                            <!-- Barra de búsqueda -->
                            <Border Grid.Row="2" Background="#2A2A33" CornerRadius="8" Padding="12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="White" CaretBrush="White"
                                             Padding="0,10"
                                             FontSize="14"/>
                                </Grid>
                            </Border>

                            <!-- DataGrid de Ventas -->
                            <DataGrid Grid.Row="4"
                                      ItemsSource="{Binding Ventas}"
                                      SelectedItem="{Binding SelectedVenta}"
                                      IsReadOnly="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.CanContentScroll="True"
                                      Background="#1E1E24"
                                      RowBackground="#1E1E24"
                                      AlternatingRowBackground="#22222C"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#2D2D3A"
                                      HeadersVisibility="Column"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False">

                                <!-- Estilos de fila hover -->
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="#1E1E24"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#28283A"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#2D2D50"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.Columns>
                                    <!-- ID corto -->
                                    <DataGridTextColumn Header="ID" Width="100" IsReadOnly="True">
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="InvoiceNumber" Converter="{x:Null}"/>
                                        </DataGridTextColumn.Binding>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding InvoiceNumber}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Fecha -->
                                    <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat={}{0:dd/MM/yy HH:mm}}"
                                                        Width="130" IsReadOnly="True"/>

                                    <!-- Cliente -->
                                    <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente}"
                                                        Width="*" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding Cliente}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Método de Pago -->
                                    <DataGridTextColumn Header="Método Pago" Binding="{Binding MetodoPago}"
                                                        Width="120" IsReadOnly="True"/>

                                    <!-- Total -->
                                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C}"
                                                        Width="100" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#00E676"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Factura (Detalles Modal) -->
                                    <DataGridTemplateColumn Header="Factura" Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                                        ToolTip="Ver detalle"
                                                        Style="{StaticResource SmallIconButton}"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Command="{Binding DataContext.ShowSaleDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Estado Badge -->
                                    <DataGridTemplateColumn Header="Estado" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="20" Padding="10,4"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1A2840"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Estado}" Value="Cancelada">
                                                                    <Setter Property="Background" Value="#3D0F0F"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Estado}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#38BDF8"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                                                        <Setter Property="Foreground" Value="#FBBF24"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Estado}" Value="En Deuda">
                                                                        <Setter Property="Foreground" Value="#F97316"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Estado}" Value="Cancelada">
                                                                        <Setter Property="Foreground" Value="#F87171"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Acciones -->
                                    <DataGridTemplateColumn Header="Acciones" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Acciones ▾"
                                                        Padding="10,4"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                                    <Button.Triggers>
                                                        <EventTrigger RoutedEvent="Button.Click">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <BooleanAnimationUsingKeyFrames Storyboard.TargetProperty="ContextMenu.IsOpen">
                                                                        <DiscreteBooleanKeyFrame KeyTime="0" Value="True"/>
                                                                    </BooleanAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Button.Triggers>
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Ver Detalles" 
                                                                      Command="{Binding PlacementTarget.Tag.ShowSaleDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <MenuItem Header="Cancelar Venta" 
                                                                      Command="{Binding PlacementTarget.Tag.CancelarVentaCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <MenuItem Header="Eliminar" 
                                                                      Command="{Binding PlacementTarget.Tag.EliminarVentaCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ====== CLIENTES TAB ====== -->
            <TabItem Header="Clientes">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Clientes" FontSize="32" FontWeight="Bold" />
                            <TextBlock Text="Gestiona tus clientes y sus cuentas corrientes."
                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="+ Nuevo Cliente"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Top"
                                Command="{Binding OpenNewClientCommand}" />
                    </Grid>

                    <!-- Search Bar -->
                    <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="16" Margin="0,0,0,16">
                        <TextBox Text="{Binding ClientSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchClientsCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </Border>

                    <!-- Content: Form + DataGrid -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Client Form Panel -->
                        <Border Grid.Column="0" Width="340" Style="{StaticResource PanelBorder}" Padding="18" Visibility="{Binding IsClientFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Datos del cliente" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />

                                <TextBlock Text="Nombre" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                <TextBox Margin="0,0,0,12"
                                         Text="{Binding ClientNombre, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Teléfono / Contacto" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                <TextBox Margin="0,0,0,20"
                                         Text="{Binding ClientTelefono, UpdateSourceTrigger=PropertyChanged}" />

                                <UniformGrid Columns="3" Margin="0,0,0,0">
                                    <Button Content="Cancelar" Margin="0,0,8,0"
                                            Style="{StaticResource RoundedButton}"
                                            Command="{Binding CancelClientEditCommand}" />
                                    <Button Content="Guardar" Margin="0,0,8,0"
                                            Style="{StaticResource PrimaryButton}"
                                            Command="{Binding SaveClientCommand}" />
                                    <Button Content="Eliminar"
                                            Style="{StaticResource DangerButton}"
                                            Command="{Binding DeleteClientCommand}" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Client DataGrid -->
                        <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="16">
                            <DataGrid ItemsSource="{Binding Clients}"
                                      SelectedItem="{Binding SelectedClient}"
                                      IsReadOnly="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.CanContentScroll="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Cliente" Binding="{Binding Nombre}" Width="*" />
                                    <DataGridTextColumn Header="Contacto" Binding="{Binding Telefono}" Width="140" />
                                    <DataGridTextColumn Header="Compras" Binding="{Binding TotalCompras}" Width="90" />
                                    <DataGridTextColumn Header="Deuda Total" Binding="{Binding DeudaTotal, StringFormat=C}" Width="120" />
                                    <DataGridTextColumn Header="Registro" Binding="{Binding FechaRegistro}" Width="160" />
                                    <DataGridTemplateColumn Header="Acciones" Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Content="Ver Cuenta"
                                                            Style="{StaticResource PrimaryButton}"
                                                            Padding="10,4"
                                                            Margin="0,0,4,0"
                                                            MinHeight="34"
                                                            Command="{Binding DataContext.OpenClientAccountCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="✏"
                                                            ToolTip="Editar"
                                                            Style="{StaticResource SmallIconButton}"
                                                            Command="{Binding DataContext.OpenEditClientCommand,
                                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="0,0,4,0" />
                                                    <Button ToolTip="Eliminar"
                                                            Style="{StaticResource DangerButton}"
                                                            Padding="6,4"
                                                            MinHeight="34"
                                                            Command="{Binding DataContext.DeleteClientCommand,
                                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" />
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- Footer -->
                    <Border Grid.Row="3" Style="{StaticResource PanelBorder}" Padding="14,10" Margin="0,16,0,0">
                        <Grid>
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12">
                                <Run Text="Mostrando" />
                                <Run Text="{Binding Clients.Count, Mode=OneWay}" />
                                <Run Text="cliente(s)" />
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Client Account Modal -->
        <Grid Background="#B2000000" Visibility="{Binding IsClientAccountVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.ColumnSpan="2">
            <Border Style="{StaticResource PanelBorder}" Background="#1E1E24" Width="600" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xEA8C;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding SelectedClient.Nombre, StringFormat=Cuenta Corriente: {0}}" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SelectedClient.DeudaTotal, StringFormat=Deuda Total: {0:C}}" FontSize="20" FontWeight="Bold" Foreground="#F97316" Margin="20,0,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding CurrentClientDebts}" 
                              IsReadOnly="True" AutoGenerateColumns="False" MaxHeight="300"
                              Background="#2A2A33" RowBackground="#2A2A33" AlternatingRowBackground="#2D2D3A"
                              BorderThickness="1" BorderBrush="#3A3A44" HeadersVisibility="Column"
                              Margin="0,0,0,16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="160"/>
                            <DataGridTextColumn Header="Factura" Binding="{Binding InvoiceNumber}" Width="*"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C}" Width="100"/>
                            <DataGridTemplateColumn Header="Acciones" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Pagar"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="10,4"
                                                Command="{Binding DataContext.PayClientDebtCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="2" Content="Cerrar" Style="{StaticResource RoundedButton}" HorizontalAlignment="Right" Command="{Binding CloseClientAccountCommand}" Padding="20,8"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Sale Details Modal -->
        <Grid Background="#B2000000" Visibility="{Binding Metricas.IsSaleDetailsVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.ColumnSpan="2">
            <Border Style="{StaticResource PanelBorder}" Background="#1E1E24" Width="500" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0"/>
                        <TextBlock Text="Detalle de Venta" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Metricas.SelectedVentaDetalles}" 
                              IsReadOnly="True" AutoGenerateColumns="False" MaxHeight="300"
                              Background="#2A2A33" RowBackground="#2A2A33" AlternatingRowBackground="#2D2D3A"
                              BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#3A3A44">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Producto" Binding="{Binding ProductoNombre}" Width="*" />
                            <DataGridTextColumn Header="Cant" Binding="{Binding Cantidad}" Width="60" />
                            <DataGridTextColumn Header="Precio" Binding="{Binding PrecioUnitario, StringFormat=C}" Width="90" />
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="2" Content="Cerrar" Style="{StaticResource PrimaryButton}" Margin="0,20,0,0" HorizontalAlignment="Right" Command="{Binding Metricas.CloseSaleDetailsCommand}" Width="100"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
