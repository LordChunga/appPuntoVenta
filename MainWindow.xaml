<Window x:Class="MiniPosWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Despensa Isabel - Punto de Venta"
        Height="820"
        Width="1280"
        MinHeight="720"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        Foreground="White"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#121212" />
        <SolidColorBrush x:Key="PanelBackground" Color="#1E1E24" />
        <SolidColorBrush x:Key="PanelBackgroundAlt" Color="#24242C" />
        <SolidColorBrush x:Key="AccentBrush" Color="#5E42A6" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#33295A" />
        <SolidColorBrush x:Key="TotalBrush" Color="#00E676" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B6B6C3" />
        <SolidColorBrush x:Key="DimTextBrush" Color="#7E7E8B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF5252" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FFA726" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundAlt}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A33" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A33" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="MinHeight" Value="46" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#17171C" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,34">
                    <Border Width="46" Height="46" CornerRadius="23" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="D" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Despensa Isabel" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Propietario" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="OPERACIÓN" Foreground="{StaticResource DimTextBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ListBox SelectedIndex="0">
                            <ListBoxItem Content="Punto de Venta" />
                            <ListBoxItem Content="Historial de ventas" />
                            <ListBoxItem Content="Compras" />
                        </ListBox>

                        <TextBlock Text="CATÁLOGO" Foreground="{StaticResource DimTextBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,24,0,8" />
                        <ListBox>
                            <ListBoxItem Content="Productos" />
                            <ListBoxItem Content="Inventario" />
                            <ListBoxItem Content="Categorías" />
                        </ListBox>

                        <TextBlock Text="PERSONAS" Foreground="{StaticResource DimTextBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,24,0,8" />
                        <ListBox>
                            <ListBoxItem Content="Clientes" />
                            <ListBoxItem Content="Proveedores" />
                        </ListBox>

                        <TextBlock Text="ANÁLISIS" Foreground="{StaticResource DimTextBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,24,0,8" />
                        <ListBox>
                            <ListBoxItem Content="Reportes" />
                            <ListBoxItem Content="Movimientos" />
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="16" Margin="0,22,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" FontSize="18" Margin="0,0,10,0" />
                            <StackPanel>
                                <TextBlock Text="Mi Caja" FontWeight="SemiBold" />
                                <TextBlock Text="Abierta" FontSize="12" Foreground="{StaticResource TotalBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="$1000.00" FontSize="24" FontWeight="Bold" Margin="0,0,0,12" />
                        <Button Content="Gestionar Caja" Style="{StaticResource RoundedButton}" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal">
                    <Border Width="38" Height="38" CornerRadius="19" Background="#2A2A33">
                        <TextBlock Text="I" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Isabel" FontWeight="SemiBold" />
                        <TextBlock Text="Sesión activa" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Punto de Venta" FontSize="32" FontWeight="Bold" />
                    <TextBlock Text="Escaneá productos, revisá el carrito y procesá la venta." Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Tema" Style="{StaticResource RoundedButton}" Margin="0,0,10,0" />
                    <Button Content="Tutorial" Style="{StaticResource RoundedButton}" Margin="0,0,10,0" />
                    <Button Content="Más Opciones" Style="{StaticResource RoundedButton}"
                            Command="{Binding MasOpcionesCommand}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,26,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelBorder}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding BusquedaProducto, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Buscar producto por código de barras o código interno">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding AddCodeToCartCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2" Content="Consultar Precio" Style="{StaticResource RoundedButton}"
                                    Command="{Binding ConsultarPrecioCommand}" />
                            <Button Grid.Column="4" Content="Ingresar Peso" Style="{StaticResource RoundedButton}"
                                    Command="{Binding IngresarPesoCommand}" />
                            <Button Grid.Column="6" Content="+ Nuevo Producto" Style="{StaticResource RoundedButton}"
                                    Command="{Binding NuevoProductoCommand}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource PanelBorder}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource DimTextBrush}"
                                       FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,16" />
                            <TextBlock Text="Carrito vacío" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="Busca productos para agregar" Foreground="{StaticResource MutedTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Cliente" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                            <ComboBox ItemsSource="{Binding Clientes}"
                                      SelectedItem="{Binding ClienteSeleccionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Items" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding ItemsCount}" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Descuentos" Foreground="{StaticResource DangerBrush}" />
                                <TextBlock Text="{Binding Descuentos, StringFormat=C}" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid Margin="0,0,0,22">
                                <TextBlock Text="Recargos" Foreground="{StaticResource WarningBrush}" />
                                <TextBlock Text="{Binding Recargos, StringFormat=C}" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Right" />
                            </Grid>

                            <TextBlock Text="{Binding Total, StringFormat=Total {0:C}}" Foreground="{StaticResource TotalBrush}"
                                       FontSize="38" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,0,18" />
                            <Button Content="Procesar Venta (Doble Enter)"
                                    Style="{StaticResource PrimaryButton}"
                                    FontSize="16"
                                    MinHeight="64"
                                    Margin="0,0,0,12"
                                    Command="{Binding ProcesarVentaCommand}" />
                            <Button Content="% Gestionar Extras"
                                    Style="{StaticResource RoundedButton}"
                                    Background="#33333C"
                                    Command="{Binding GestionarExtrasCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
